# Copy this file to .env.local and fill values for local development
# Do NOT commit your real API keys.

# SendGrid API key (get one from https://sendgrid.com)
SENDGRID_API_KEY=

# Comma-separated list of recipient emails to notify when forms are submitted
CONTACT_RECIPIENTS=your.email@domain.com

# Sender email used for the From header (must be a verified sender in SendGrid)
SENDER_EMAIL=your.email@domain.com
# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile → Add site)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=